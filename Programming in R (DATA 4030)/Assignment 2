# Find the frequency of each of storm categories per year and 
# remove missing values of categories
storms_by_category <- storms |>
  group_by(category, year) |>
  filter(!is.na(category)) |>
  summarize(frequency = n(), .groups = "drop")

storms_by_category

# Find the storms occurred more than 100 frequency and call it storms_outliers
storms_outliers <- storms_by_category |>
  filter(frequency > 100)

storms_outliers

# create a scatter plot to show the frequency of storms per year
storms_by_category |>
  ggplot(aes(x = year, y = frequency)) +
  geom_point(color = "grey", size = 2) +
  geom_point(data = storms_by_category |> filter(category == 4),
             shape = 8, size = 2, color = "red") + 
  geom_smooth(data = storms_by_category |> filter(category == 4),
