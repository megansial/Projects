RUN;

/*Since CBC_MCHC is being imported as a character, we cannot move forward and use Proc Means because 
CBC_MCHC needs to be quantitative. This could mean that there are NA, NaN, ?, . " " or even a -1 and 999 
classified as a character.*/
/*******************************************************************/
/*** END: Check how SAS is importing the data  ***/
/*******************************************************************/


/***************************************************************************************/
/*      BEGIN: CHECK DATA FOR what is making CBC_MCHC a character		*********************/
/**************************************************************************************/

/* Look for NA, NaN, ?, . " " or even a -1 and 999 that is classifying CBC_MCHC as a character.*/
PROC FREQ DATA=work.myeloma2;
Table CBC_MCHC;
run;
/* All the way at the bottom of the table, it shows that the data contains a question mark. 
	This is what is making CBC_MCHC categorical instead of quantitative. */

/* Delete question marks */
data work.myeloma_clean;
set work.myeloma2;
if CBC_MCHC='?' then delete;
run;

/* Verify that the ?'s are gone. */
PROC FREQ DATA=work.myeloma_clean;
Table CBC_MCHC;
run;

/***************************************************************************************/
/*      END: CHECK DATA FOR what is making CBC_MCHC a character	  ********************/
/***************************************************************************************/


/*********************************/
/*   change MCHC to quantitative */
/*********************************/

/* Before you can look for the -1 and 999 values with Proc Means, CBC_MCHC must be 
classified as a quantitative variable. */

data work.myeloma_clean;
set work.myeloma_clean;
CBC_MCHC_num = CBC_MCHC*1; 
run; 

/***************************************************************************************/
/*      BEGIN: CHECK FOR CORRECT CLASSIFICATION OF VARIABLES (QUANTITATIVE/CATEGORICAL) *********************/
/***************************************************************************************/

