/**************************************************************************************************/
/*   BEGINNING: NONPARAMETRIC TEST OF LOCATION AND THE POST HOC CONFIDENCE INTERVAL ON THE MEDIAN */
/**************************************************************************************************/

/* THE SIGN TEST  */
proc Univariate data=work.ctcp_tidy_clean
	mu0=49
	loccount
	cipctldf
	alpha=.05;
	where Semester = 3;
	var Score;
Run;

/********************************************************************************************/
/*   END: NONPARAMETRIC TEST OF LOCATION AND THE POST HOC CONFIDENCE INTERVAL ON THE MEDIAN */
