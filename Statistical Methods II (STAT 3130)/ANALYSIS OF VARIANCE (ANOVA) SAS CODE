/***************************************************************/
/*** Getting the values for the 33rd and 66th percentile. ***/
/***************************************************************/
proc univariate data=work.data_sci_clean;
    var "Avg Salary"n;
    output out=work.data_sci_33_66
	pctlpts = 33, 66
	pctlpre = P_;
run;

