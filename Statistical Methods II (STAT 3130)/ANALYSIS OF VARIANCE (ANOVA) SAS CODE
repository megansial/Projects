run;
**The correct 33rd percentile is 81. The 66th percentile is 111.5. **;


/* break the average salaries (T) in the data scientist data set into thirds. 
Include the lower bound of the interval but not the upper bound when you break into levels. 
Use 33rd percentile, 66 percentile to break into thirds. 
This is done with if-then-else programming. */
data work.data_sci_clean;
set work.data_sci_clean;
 	if "Avg Salary"n < 81 then "Salary Category"n = 1;
	else if 81 <= "Avg Salary"n < 111.5 then "Salary Category"n = 2;
	else if "Avg Salary"n >= 111.5 then "Salary Category"n = 3;
RUN;

* Break the data into categories using 1, 2, 3 so the levels are ordered properly;
* Step 2: Create the format equivalents you want for 1, 2, 3. They can have spaces in the formats.;
Proc format;
Value salaryformat
1 = "Under $81,000"
2 = "$81,000 to < $111,500"
3 = "$111,500 and over";
run;

* Step 3: Attach the format statement to the data set. ;
data work.data_sci_clean;
set work.data_sci_clean;
format "Salary Category"n salaryformat.;
run;

PROC FREQ data=work.data_sci_clean;
tables "Salary Category"n;
run;
/*The amount of job listings in each of the three groups are  233 246 252.*/

/*******************************************************************************/
/*** BEGINNING: Check for Normality of Rating for All Three Avg Salaries(K) ***/
/*****************************************************************************/
/* 
H_0: All ratings for all three average salaries follow a normal distribution
H_a: All ratings for all three average salaries do NOT follow a normal distribution.
*/



ods graphics on / height=8 in width=6 in  outputfmt=svg;
title 'QQ Plots for Rating by Average Salary';
proc univariate data=work.data_sci_clean normaltest plots;  
	class "Salary Category"n; /*CATEGORICAL*/
	var "Glassdoor Rating"n; /*QUANTITATIVE*/
title;

/* NORMALITY CONCLUSION: Since the Glassdoor Ratings for all three-salary categories are 
approximately not normal enough, we use the Central Limit Theorem to conclude that the x-bar
is approximately normal because all three salary categories have sample sizes (n = 233, 246, 252) 
greater than 30 (n>30). Therefore, we should choose a parametric test to analyze these three salary categories. */
/********************************************************************/
/*** END: Check for Normality of Rating for All Three Diets ***/
/********************************************************************/


/************************************************************/
/*** BEGINNING: Levene's Homogeneity Test ***/
/************************************************************/ 
ods graphics on / outputfmt=svg;
proc ANOVA data=WORK.data_sci_clean;
   class "Salary Category"n;
   model "Glassdoor Rating"n = "Salary Category"n;
   means "Salary Category"n / hovtest=levene(type=SQUARE); /* second check on homogeneity */
run;
ods graphics off;

/* Conclusion: Since the p-value of 0.5813 is greater than the alpha of 0.05, we cannot reject 
the H_0: σ_(<81K)^2=σ_(81K to<111.5K)^2=σ_(>111.5K)^2. The sample variances are homogenous enough to pool. */

/* Thus, with normality of the x ̅  distributions for all three average salary categories, 
and homogeneity of the x distributions for all three average salary categories, 
we choose ANOVA as the appropriate test. */

/************************************************************/
/*** END: Levene Homogeneity Test ***/
/************************************************************/ 


/**********************************************/
/*********** BEGINNING: ONE-WAY ANOVA**********/
/**********************************************/

/* ONE-WAY ANOVA PROCEDURE  */
ods graphics on / outputfmt=svg;
proc ANOVA data=WORK.data_sci_clean;
   class "Salary Category"n;
   model "Glassdoor Rating"n = "Salary Category"n;
   means "Salary Category"n;
run;
quit;
ods graphics off;
/* sample averages (3.782, 3.666, 3.611)*/

/*Conclusion:	Since 0.0032 is less than the significance level of 0.05, 
we reject that the hypothesis that all salary categories have the same average Glassdoor rating. 
We are 95% confident that at least one salary category has a different average Glassdoor rating, 
however we would need a post-hoc test to find out which categories are different.*/

proc means data=work.data_sci_clean;
var "Glassdoor Rating"n;
run;
/* overall average mean (3.688) */

/**********************************************/
/*********** END: ONE-WAY ANOVA****************/
/**********************************************/


/*************************************************/
/*********** BEGINNING: POST-HOC TESTS  **********/
/*************************************************/

/* YOU CAN RUN THEM ALL AT ONCE TO REDUCE THE REDUNDANT ANOVA TABLES ON EACH SEPARATE RUN.  */

ods graphics on / outputfmt=svg;
proc anova data=WORK.data_sci_clean;
   class "Salary Category"n;
   model "Glassdoor Rating"n = "Salary Category"n;
   means "Salary Category"n / bon lines tukey lines lsd lines alpha = .05;
run;
ods graphics off;

/*Since all three post-hoc’s agree that “$111,500 and over” (3.7817 points) is significantly 
different than “Under $81,000” (3.6112 points), we conclude that there is a significant 
difference in the ratings.*/


/*************************************************/
/*********** END: POST-HOC TESTS  **********/
/*************************************************/




